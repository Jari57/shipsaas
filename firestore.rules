rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own user doc (includes apiKeys, profileName, plan)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Projects: owner can read/write, authenticated users can create with own userId
    match /projects/{projectId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    // Mail collection: only server (admin SDK) can write — clients cannot
    match /mail/{mailId} {
      allow read, write: if false;
    }
    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
